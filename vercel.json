{
  "version": 2,
  "framework": null,
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "buildCommand": "npm run build && mkdir -p dist",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/favicon.(ics|ico|png)",
      "dest": "/public/favicon.$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "CACHE_DRIVER": "array",
    "SESSION_DRIVER": "cookie",
    "QUEUE_CONNECTION": "sync",
    "LOG_CHANNEL": "stderr"
  }
}